{
  "rule_id": "VS-LIFE-RCU-DEFER-001",
  "family": "rcu_deferred_release",
  "description": "Immediate release after RCU-list deletion is replaced by a fixed-view deferred release through call_rcu.",
  "candidate_selectors": {
    "fixed_window_contains": ["call_rcu"],
    "vulnerable_window_contains": ["list_del_rcu"]
  },
  "vulnerable_required": null,
  "fixed_required": {
    "callee": "call_rcu",
    "role": "defer_free_rcu"
  },
  "source_window_required": ["list_del_rcu"],
  "source_window_any_of": ["llsec_key_put", "kref_put", "kfree", "kfree_sensitive"],
  "matching": {
    "require_function": false,
    "line_slop": 3,
    "require_same_file": true
  },
  "negative_policy": {
    "enabled": true,
    "scope": "rule_trigger_absent_in_candidate_window"
  },
  "label_strength": "codeql_conditional",
  "label_reason": "CodeQL facts show fixed call_rcu in the candidate window, while the vulnerable source window shows RCU-list deletion with immediate release/free evidence."
}
